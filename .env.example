# Корень данных на диске D (не C!)
DATA_ROOT=D:/bars-support-bot-data

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_SUPPORT_CHAT_ID=

# === LLM ===
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_VISION_MODEL=

# === Embeddings (кэш на D:, см. setup_d_drive.ps1) ===
EMBED_PROVIDER=sentence-transformers
EMBED_MODEL=intfloat/multilingual-e5-base
HF_HOME=D:/bars-support-bot-data/huggingface
TRANSFORMERS_CACHE=D:/bars-support-bot-data/huggingface
SENTENCE_TRANSFORMERS_HOME=D:/bars-support-bot-data/huggingface

GIGACHAT_CREDENTIALS=
AUTO_INDEX_ON_START=true

# === Qdrant / Redis ===
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=bars_docs
REDIS_URL=redis://127.0.0.1:6379/0

# === RAG ===
CONFIDENCE_THRESHOLD=0.55
TOP_K_CHUNKS=5

# === API ===
APP_HOST=0.0.0.0
APP_PORT=8026
DOCS_DIR=data/docs
UPLOAD_DIR=data/uploads
BOT_NAME=DocHelper Барс

# pip-кэш (локальный запуск без Docker)
PIP_CACHE_DIR=D:/bars-support-bot-data/pip-cache

# Только один процесс Telegram: local ИЛИ docker app
TELEGRAM_ENABLED=true
